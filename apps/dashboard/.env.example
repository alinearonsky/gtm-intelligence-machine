# Supabase TRANSACTION POOLER connection (port 6543), NOT the direct 5432 URL.
DASHBOARD_DATABASE_URL=postgres://USER:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres

# 'public' (read-only demo) or 'private' (full control). Unset/unknown => public.
INSTANCE_MODE=public

# Required ONLY when INSTANCE_MODE=private. The private instance refuses to boot
# (503) without both. Never commit real values.
DASHBOARD_BASIC_AUTH_USER=
DASHBOARD_BASIC_AUTH_PASS=
