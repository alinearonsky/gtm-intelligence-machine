{
  "name": "gtm-intelligence-machine",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "vitest run",
    "test:db": "vitest run --project db",
    "scan": "tsx packages/worker/src/index.ts",
    "migrate": "tsx packages/worker/scripts/migrate.ts",
    "extract": "tsx packages/worker/src/extract-cli.ts",
    "interpret": "tsx packages/worker/src/interpret-cli.ts",
    "narrate": "tsx packages/worker/src/narrate-cli.ts",
    "dev:dashboard": "npm run dev -w apps/dashboard",
    "build:dashboard": "npm run build -w apps/dashboard"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "dependencies": {
    "@vercel/analytics": "^2.0.1"
  }
}
