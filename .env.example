# Postgres connection string (Supabase: Project Settings → Database → Connection string, URI, port 5432)
DATABASE_URL=postgres://user:password@host:5432/postgres
# Anthropic API key for the extraction pass (Claude Haiku 4.5). Only the
# `extract` step needs it; scan and interpret do not.
ANTHROPIC_API_KEY=sk-ant-...
# Optional: path to a watchlist file (defaults to watchlists/demo.yaml)
# WATCHLIST=watchlists/demo.yaml
